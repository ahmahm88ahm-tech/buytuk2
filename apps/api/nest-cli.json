{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "tsconfig.json"
  },
  "projects": {
    "streaming": {
      "type": "library",
      "root": "src",
      "entryFile": "modules/streaming/streaming.module.ts",
      "sourceRoot": "src/modules/streaming",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    }
  }
}
